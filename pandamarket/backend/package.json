{
  "name": "pandamarket-backend",
  "version": "1.0.0",
  "description": "PandaMarket MaaS Backend — MedusaJS v2",
  "private": true,
  "scripts": {
    "dev": "medusa develop",
    "start": "medusa start",
    "build": "medusa build",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "migration:run": "medusa migrations run",
    "migration:generate": "medusa migrations generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@medusajs/admin-sdk": "2.14.2",
    "@medusajs/framework": "2.14.2",
    "@medusajs/medusa": "2.14.2",
    "@medusajs/medusa-cli": "1.3.23",
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/s3-request-presigner": "^3.500.0",
    "meilisearch": "^0.44.0",
    "zod": "^3.23.0",
    "jsonwebtoken": "^9.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
