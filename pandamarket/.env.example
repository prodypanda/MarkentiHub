# =============================================================================
# PandaMarket — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# === Application ===
PD_NODE_ENV=development
PD_PORT=9000
PD_ADMIN_CORS=http://localhost:3000
PD_STORE_CORS=http://localhost:3000
PD_HUB_DOMAIN=pandamarket.local

# === Database (PostgreSQL) ===
PD_DATABASE_URL=postgresql://pd_user:pd_dev_password_2026@localhost:5432/pandamarket
PD_DATABASE_POOL_SIZE=20

# === Redis ===
PD_REDIS_URL=redis://localhost:6379

# === Storage (S3-Compatible — MinIO local) ===
PD_S3_ENDPOINT=http://localhost:9000
PD_S3_BUCKET_PUBLIC=pd-product-images
PD_S3_BUCKET_PRIVATE=pd-private-files
PD_S3_BUCKET_THEMES=pd-themes
PD_S3_ACCESS_KEY=pd_minio_admin
PD_S3_SECRET_KEY=pd_minio_secret_2026
PD_S3_REGION=us-east-1

# === Payments — Flouci (sandbox) ===
PD_FLOUCI_APP_TOKEN=sandbox_flouci_token
PD_FLOUCI_APP_SECRET=sandbox_flouci_secret
PD_FLOUCI_BASE_URL=https://developers.flouci.com/api

# === Payments — Konnect (sandbox) ===
PD_KONNECT_API_KEY=sandbox_konnect_key
PD_KONNECT_RECEIVER_WALLET=sandbox_konnect_wallet
PD_KONNECT_BASE_URL=https://api.konnect.network/api/v2

# === AI — Google Gemini ===
PD_GEMINI_API_KEY=your_gemini_api_key
PD_GEMINI_MODEL=gemini-2.0-pro
PD_GEMINI_MAX_TOKENS=500

# === Search — Meilisearch ===
PD_MEILI_HOST=http://localhost:7700
PD_MEILI_MASTER_KEY=pd_meili_master_dev_key_2026

# === Auth — JWT ===
PD_JWT_SECRET=pd_dev_jwt_secret_change_in_production_2026
PD_JWT_EXPIRY=15m
PD_REFRESH_TOKEN_SECRET=pd_dev_refresh_secret_change_in_production_2026
PD_REFRESH_TOKEN_EXPIRY=7d
PD_COOKIE_SECRET=pd_dev_cookie_secret_change_in_production_2026

# === Encryption — AES-256-GCM (for vendor payment keys) ===
PD_ENCRYPTION_KEY=pd_dev_encryption_key_32chars!!

# === Webhook Signing ===
PD_WEBHOOK_SECRET=pd_dev_webhook_secret_2026

# === Frontend (Next.js) ===
NEXT_PUBLIC_MEDUSA_URL=http://localhost:9000
NEXT_PUBLIC_HUB_DOMAIN=pandamarket.local
NEXT_PUBLIC_MEILI_HOST=http://localhost:7700
NEXT_PUBLIC_MEILI_SEARCH_KEY=pd_meili_search_dev_key
